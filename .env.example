# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ─── Supabase (required) ──────────────────────────────────────────
# From your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App URL (required) ───────────────────────────────────────────
# Used for email links and redirects. Set to your production URL when deploying.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Phase 1: Email + Cron ────────────────────────────────────────
# Resend (https://resend.com) — sign up, verify a sending domain, generate API key
RESEND_API_KEY=re_your_key_here
RESEND_FROM="Orbit <no-reply@orbitsocial.net>"

# Random 32-byte hex secret used by Vercel Cron + internal trigger fan-out.
# Generate: openssl rand -hex 32
CRON_SECRET=replace-with-32-byte-hex-secret

# Signing secret from Supabase Dashboard → Authentication → Hooks → Send email hook.
# Used by /api/auth/email-hook to verify the standardwebhooks signature.
# Without this set, the route falls back to a dev-mode warning instead of verifying.
SUPABASE_AUTH_HOOK_SECRET=v1,whsec_replace-with-supabase-hook-secret

# ─── Phase 3.3: Turnstile CAPTCHA (via Supabase) ──────────────────
# Cloudflare Turnstile site key (publishable). Set in Supabase Dashboard
# → Authentication → Settings → Bot Protection — but ALSO needed here so
# the client widget can render. Leave blank locally to skip CAPTCHA in dev.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAB...

# ─── Phase 3.1: Observability (Sentry) ────────────────────────────
# Sentry (https://sentry.io) — sign up, create a Next.js project, copy DSN + auth token
# Without DSN set, Sentry is a no-op (safe to leave blank locally).
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oxxxxxx.ingest.us.sentry.io/xxxxxxx
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxx
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=orbit-social

# ─── Phase 2: Live streaming (Mux) ────────────────────────────────
# MUX_TOKEN_ID=your-mux-token-id
# MUX_TOKEN_SECRET=your-mux-token-secret
# MUX_WEBHOOK_SECRET=your-mux-webhook-signing-secret
# NEXT_PUBLIC_MUX_ENV_KEY=your-mux-data-env-key

# ─── Phase 4: TURN server for WebRTC calls ────────────────────────
# Cloudflare Calls TURN (free tier) or Twilio NTS
# TURN_TOKEN_ID=your-cloudflare-turn-token-id
# TURN_TOKEN_SECRET=your-cloudflare-turn-token-secret

# ─── Phase 5: Rate limit + Push ───────────────────────────────────
# Upstash Redis (https://upstash.com) — sliding-window rate limiter
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# Web Push (VAPID keys)
# Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@orbit.app
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=  # mirror of VAPID_PUBLIC_KEY for client subscribe
